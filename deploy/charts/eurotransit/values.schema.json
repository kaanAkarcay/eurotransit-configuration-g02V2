{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "canaryConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "path", "initialWeight"],
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "pattern": "^/" },
        "initialWeight": { "type": "integer", "minimum": 1, "maximum": 99 }
      }
    },
    "imageConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "digest": {
          "type": "string",
          "anyOf": [
            { "maxLength": 0 },
            { "pattern": "^sha256:[a-f0-9]{64}$" }
          ]
        }
      }
    }
  },
  "properties": {
    "deploymentStrategies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frontend", "catalog", "orders"],
      "properties": {
        "frontend": { "type": "string", "enum": ["standard", "canary", "blueGreen"] },
        "catalog": { "type": "string", "enum": ["standard", "canary", "blueGreen"] },
        "orders": { "type": "string", "enum": ["standard", "canary", "blueGreen"] }
      }
    },
    "blueGreen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inventory", "payments"],
      "properties": {
        "inventory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": { "enabled": { "type": "boolean" } }
        },
        "payments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": { "enabled": { "type": "boolean" } }
        }
      }
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frontend", "catalog", "orders"],
      "properties": {
        "frontend": { "$ref": "#/definitions/canaryConfig" },
        "catalog": { "$ref": "#/definitions/canaryConfig" },
        "orders": { "$ref": "#/definitions/canaryConfig" }
      }
    },
    "frontend": {
      "type": "object",
      "properties": { "image": { "$ref": "#/definitions/imageConfig" } }
    },
    "catalog": {
      "type": "object",
      "properties": { "image": { "$ref": "#/definitions/imageConfig" } }
    },
    "orders": {
      "type": "object",
      "properties": { "image": { "$ref": "#/definitions/imageConfig" } }
    },
    "inventory": {
      "type": "object",
      "properties": { "image": { "$ref": "#/definitions/imageConfig" } }
    },
    "payments": {
      "type": "object",
      "properties": { "image": { "$ref": "#/definitions/imageConfig" } }
    },
    "progressiveDelivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaleDownDelaySeconds", "progressDeadlineSeconds", "progressDeadlineAbort", "minReadySeconds", "revisionHistoryLimit", "rollbackWindowRevisions", "automatedAnalysis", "blueGreen"],
      "properties": {
        "scaleDownDelaySeconds": { "type": "integer", "minimum": 30 },
        "progressDeadlineSeconds": { "type": "integer", "minimum": 60 },
        "progressDeadlineAbort": { "type": "boolean" },
        "minReadySeconds": { "type": "integer", "minimum": 0 },
        "revisionHistoryLimit": { "type": "integer", "minimum": 2 },
        "rollbackWindowRevisions": { "type": "integer", "minimum": 1 },
        "automatedAnalysis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "services",
            "prometheusAddress",
            "duration",
            "interval",
            "safetyWarmup",
            "safetyQueryWindow",
            "canaryWeights",
            "minimumRequests",
            "ordersMinimumRequests",
            "maximumP95LatencySeconds",
            "failureLimit",
            "inconclusiveLimit",
            "consecutiveErrorLimit",
            "progressDeadlineSafetyMarginSeconds",
            "postPromotionSafetyMarginSeconds"
          ],
          "properties": {
            "services": {
              "type": "object",
              "additionalProperties": false,
              "required": ["frontend", "catalog", "orders", "inventory", "payments"],
              "properties": {
                "frontend": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["enabled"],
                  "properties": { "enabled": { "type": "boolean" } }
                },
                "catalog": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["enabled"],
                  "properties": { "enabled": { "type": "boolean" } }
                },
                "orders": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["enabled"],
                  "properties": { "enabled": { "type": "boolean" } }
                },
                "inventory": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["enabled"],
                  "properties": { "enabled": { "type": "boolean" } }
                },
                "payments": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["enabled"],
                  "properties": { "enabled": { "type": "boolean" } }
                }
              }
            },
            "prometheusAddress": { "type": "string", "pattern": "^https?://" },
            "duration": { "type": "string", "pattern": "^[1-9][0-9]*[smh]$" },
            "interval": { "type": "string", "pattern": "^[1-9][0-9]*[smh]$" },
            "safetyWarmup": { "type": "string", "pattern": "^[1-9][0-9]*[smh]$" },
            "safetyQueryWindow": { "type": "string", "pattern": "^[1-9][0-9]*[smh]$" },
            "canaryWeights": {
              "type": "array",
              "minItems": 2,
              "uniqueItems": true,
              "items": { "type": "integer", "minimum": 1, "maximum": 100 }
            },
            "minimumRequests": { "type": "integer", "minimum": 1 },
            "ordersMinimumRequests": { "type": "integer", "minimum": 1 },
            "maximumP95LatencySeconds": { "type": "number", "exclusiveMinimum": 0 },
            "failureLimit": { "type": "integer", "minimum": 0 },
            "inconclusiveLimit": { "type": "integer", "minimum": 0 },
            "consecutiveErrorLimit": { "type": "integer", "minimum": 0 },
            "progressDeadlineSafetyMarginSeconds": { "type": "integer", "minimum": 1 },
            "postPromotionSafetyMarginSeconds": { "type": "integer", "minimum": 1 }
          }
        },
        "blueGreen": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scaleDownDelaySeconds"],
          "properties": {
            "scaleDownDelaySeconds": { "type": "integer", "minimum": 30 }
          }
        }
      }
    }
  }
}
